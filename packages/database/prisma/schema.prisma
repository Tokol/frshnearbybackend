generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CONSUMER
  SIDE_HUSTLER
  BUSINESS
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DELETION_PENDING
  DELETED
}

enum OnboardingStep {
  ACCOUNT_CREATED
  EMAIL_VERIFICATION_REQUIRED
  PROFILE_REQUIRED
  ROLE_SELECTION_REQUIRED
  PRODUCER_DETAILS_REQUIRED
  BUSINESS_DETAILS_REQUIRED
  SUBMITTED_FOR_REVIEW
  COMPLETE
}

enum VerificationStatus {
  NOT_REQUIRED
  DRAFT
  SUBMITTED
  IN_REVIEW
  NEEDS_CHANGES
  VERIFIED
  REJECTED
}

enum VerificationKind {
  SIDE_HUSTLER
  BUSINESS
}

enum DocumentKind {
  IDENTITY
  BUSINESS_REGISTRATION
  VAT_REGISTRATION
  ADDRESS_PROOF
  OTHER
}

enum PushPlatform {
  ANDROID
  IOS
  WEB
  MACOS
  OTHER
}

model User {
  id                 String              @id @default(cuid())
  firebaseUid        String              @unique
  email              String?             @unique
  emailVerified      Boolean             @default(false)
  displayName        String?
  phone              String?             @unique
  dateOfBirth        DateTime?
  photoUrl           String?
  addressLine        String?
  addressUnit        String?
  city               String?
  postalCode         String?
  country            String?
  latitude           Float?
  longitude          Float?
  addressConfirmedAt DateTime?
  roles              UserRole[]          @default([CONSUMER])
  status             AccountStatus       @default(ACTIVE)
  onboardingStep     OnboardingStep      @default(ACCOUNT_CREATED)
  verificationStatus VerificationStatus  @default(NOT_REQUIRED)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  lastLoginAt        DateTime            @default(now())
  producerProfile    ProducerProfile?
  businessProfile    BusinessProfile?
  submissions        VerificationSubmission[] @relation("ApplicantSubmissions")
  reviews            VerificationSubmission[] @relation("AdminReviews")
  adminActions        AdminAuditLog[]     @relation("AdminActor")
  actionsAgainst     AdminAuditLog[]     @relation("AdminTarget")
  deletionRequest    AccountDeletion?
  pushInstallations  PushInstallation[]
  hotSales           HotSale[]

  @@index([status])
  @@index([verificationStatus])
  @@index([createdAt])
}

model RekoRing {
  id           String   @id @default(cuid())
  countryCode  String   @default("FI")
  country      String   @default("Finland")
  regionCode   String?
  regionName   String?
  municipalityCode String?
  municipality String
  name         String
  addressLine  String
  postalCode   String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  schedule     RekoMeetingSchedule?
  hotSales     HotSaleRekoRing[]

  @@unique([country, municipality, name])
  @@index([country, municipality, active])
}

enum RekoScheduleFrequency {
  WEEKLY
  BIWEEKLY
}

enum HotSaleUnit {
  KILOGRAM
  GRAM
  LITRE
  PIECE
  BUNCH
  BOX
  DOZEN
}

enum HotSaleStatus {
  ACTIVE
  PAUSED
  SOLD_OUT
  ARCHIVED
}

enum HotSaleTranslationStatus {
  PENDING
  COMPLETED
  FAILED
}

model RekoMeetingSchedule {
  id         String                @id @default(cuid())
  rekoRingId String                @unique
  frequency  RekoScheduleFrequency @default(WEEKLY)
  weekday    Int
  startTime  String
  endTime    String
  timezone   String                @default("Europe/Helsinki")
  active     Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
  rekoRing   RekoRing              @relation(fields: [rekoRingId], references: [id], onDelete: Cascade)
}

model HotSale {
  id               String        @id @default(cuid())
  sellerId         String
  productKey       String?
  variantKey       String?
  categoryKey      String        @default("other")
  originalLanguage String        @default("auto")
  detectedLanguage String?
  originalTitle    String
  description      String
  productionDetail String?
  unit             HotSaleUnit
  priceCents       Int
  quantity         Float
  producedAt       DateTime?
  availableAtFarm  Boolean       @default(false)
  status           HotSaleStatus @default(ACTIVE)
  imageName        String
  imageMimeType    String
  imageData        Bytes
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  seller           User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  rekoRings        HotSaleRekoRing[]
  translations     HotSaleTranslation[]

  @@index([sellerId, status, createdAt])
  @@index([status, createdAt])
}

model HotSaleTranslation {
  id               String                   @id @default(cuid())
  hotSaleId        String
  locale           String
  title            String
  description      String
  productionDetail String?
  status           HotSaleTranslationStatus @default(PENDING)
  provider         String?
  model            String?
  errorMessage     String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  hotSale          HotSale                  @relation(fields: [hotSaleId], references: [id], onDelete: Cascade)

  @@unique([hotSaleId, locale])
  @@index([locale, title])
}

model HotSaleRekoRing {
  hotSaleId String
  rekoRingId String
  hotSale   HotSale @relation(fields: [hotSaleId], references: [id], onDelete: Cascade)
  rekoRing  RekoRing @relation(fields: [rekoRingId], references: [id], onDelete: Restrict)

  @@id([hotSaleId, rekoRingId])
  @@index([rekoRingId])
}

model PushInstallation {
  id             String       @id @default(cuid())
  userId         String
  installationId String       @unique
  token          String       @unique
  platform       PushPlatform
  deviceName     String?
  locale         String       @default("en")
  enabled        Boolean      @default(true)
  lastSeenAt     DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, enabled])
  @@index([lastSeenAt])
}

model ProducerProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  publicName       String
  description      String?
  productionType   String?
  address          String?
  city             String?
  postalCode       String?
  country          String?
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BusinessProfile {
  id                String  @id @default(cuid())
  userId            String  @unique
  publicDisplayName String
  legalBusinessName String
  farmName          String?
  businessId        String
  vatNumber         String?
  businessType      String
  businessAddress   String
  city              String
  postalCode        String
  country           String
  logoUrl           String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId])
}

model VerificationSubmission {
  id                String             @id @default(cuid())
  applicantId       String
  kind              VerificationKind
  status            VerificationStatus @default(SUBMITTED)
  requestTitle      String?
  userMessage       String?
  userResponse      String?
  internalNotes     String?
  requestedDocumentKinds DocumentKind[] @default([])
  requiresTextResponse Boolean          @default(false)
  submittedAt       DateTime           @default(now())
  reviewedAt        DateTime?
  reviewedById      String?
  applicant         User               @relation("ApplicantSubmissions", fields: [applicantId], references: [id], onDelete: Cascade)
  reviewedBy        User?              @relation("AdminReviews", fields: [reviewedById], references: [id], onDelete: SetNull)
  documents         VerificationDocument[]

  @@index([status, submittedAt])
  @@index([applicantId])
}

model VerificationDocument {
  id            String                 @id @default(cuid())
  submissionId  String
  kind          DocumentKind
  storageKey    String
  originalName  String
  mimeType      String
  createdAt     DateTime               @default(now())
  submission    VerificationSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  actorId     String
  targetId    String?
  action      String
  reason      String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation("AdminActor", fields: [actorId], references: [id], onDelete: Restrict)
  target      User?    @relation("AdminTarget", fields: [targetId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([targetId])
}

model AccountDeletion {
  id          String   @id @default(cuid())
  userId      String   @unique
  requestedAt DateTime @default(now())
  executeAfter DateTime
  completedAt DateTime?
  lastError   String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailSignupVerification {
  id                String   @id @default(cuid())
  email             String   @unique
  firebaseUid       String?
  displayName       String?
  codeHash          String
  codeSalt          String
  attempts          Int      @default(0)
  expiresAt         DateTime
  resendAvailableAt DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([expiresAt])
}
